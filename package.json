  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "echo \"Dummy build script required for Autocode Compile\"",
    "ts-compile": "npx tsc",
    "compile": "sass src/scss:dist --no-source-map",
